# Copia este archivo como .env y completa los valores

# Genera una nueva clave en: https://djecrety.ir/
SECRET_KEY=django-insecure-cambia-esto-por-una-clave-segura

# En produccion debe ser False
DEBUG=False

# Tu dominio en Render, ej: gol-master.onrender.com
ALLOWED_HOSTS=localhost,127.0.0.1
CSRF_TRUSTED_ORIGINS=https://tu-app.onrender.com

# URL de la base de datos PostgreSQL externa, por ejemplo Neon o Supabase.
# En local puedes dejar SQLite.
DATABASE_URL=sqlite:///db.sqlite3

# Media local/temporal. En Render Free /tmp/media NO es persistente.
MEDIA_ROOT=/tmp/media
SERVE_MEDIA=True

# Media persistente opcional con storage S3-compatible, por ejemplo Supabase Storage.
# Déjalo en False si quieres seguir usando MEDIA_ROOT local/temporal.
USE_S3_MEDIA=False

# Supabase Storage S3-compatible ejemplo:
# 1. Crea un bucket público, por ejemplo: gol-master-media
# 2. En Supabase ve a Storage > S3 Access Keys y crea access/secret keys.
# 3. Usa endpoint: https://TU_PROJECT_REF.supabase.co/storage/v1/s3
# 4. Usa dominio público: TU_PROJECT_REF.supabase.co/storage/v1/object/public/NOMBRE_BUCKET
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=gol-master-media
AWS_S3_ENDPOINT_URL=https://TU_PROJECT_REF.supabase.co/storage/v1/s3
AWS_S3_REGION_NAME=us-east-1
AWS_S3_SIGNATURE_VERSION=s3v4
AWS_S3_ADDRESSING_STYLE=path
AWS_S3_CUSTOM_DOMAIN=TU_PROJECT_REF.supabase.co/storage/v1/object/public/gol-master-media
AWS_S3_URL_PROTOCOL=https:
AWS_QUERYSTRING_AUTH=False
MEDIA_URL=https://TU_PROJECT_REF.supabase.co/storage/v1/object/public/gol-master-media/

# football-data.org para marcadores/resultados.
# Obtén un token gratuito en https://www.football-data.org/client/register
FOOTBALL_DATA_TOKEN=coloca-tu-token-aqui
FOOTBALL_DATA_BASE_URL=https://api.football-data.org/v4
FOOTBALL_DATA_TIMEOUT=15

